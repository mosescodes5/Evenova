# ─── Vite build-time environment variables ──────────────────
# Prefix VITE_ is required for Vite to expose to the browser

# Backend API base URL (leave empty to use the Vite proxy in dev)
VITE_API_URL=http://localhost:4000

# Paystack public key (safe to expose — this is the PUBLIC key)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

# Flutterwave public key
VITE_FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxx

# Ticket signing secret — must match backend TICKET_SECRET
# IMPORTANT: Only set this if you move away from the hardcoded default
# VITE_TICKET_SECRET=your_shared_secret_here
