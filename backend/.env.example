# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Database (required — auth, events & tickets read/write here) ──
# Option A — PostgreSQL (wired up via Drizzle ORM, see README → Database Setup)
DATABASE_URL=postgresql://user:password@localhost:5432/evenova
# Most hosted providers (Supabase/Neon/Render) need SSL; set to false for local dev
PGSSL=true

# Option B — MongoDB (not wired up — you'd need to swap src/db/* for mongoose)
# MONGO_URI=mongodb://localhost:27017/evenova

# ─── Email (choose one provider) ───────────────────────────
EMAIL_PROVIDER=resend           # resend | ses | brevo | smtp

# Resend.com (easiest — no server needed)
RESEND_API_KEY=re_xxxxxxxxxxxx

# AWS SES via Lambda/API Gateway
SES_ENDPOINT_URL=https://your-api-gateway-url.amazonaws.com/email
SES_API_KEY=

# Brevo (Sendinblue)
BREVO_API_KEY=

# SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello.evenova@gmail.com
SMTP_PASS=

# Sender identity
EMAIL_FROM_NAME=Evenova
EMAIL_FROM_ADDRESS=noreply@evenova.ng

# ─── Payments ──────────────────────────────────────────────
# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx

# Flutterwave
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxx
FLW_SECRET_HASH=your_webhook_hash

# ─── File Storage ──────────────────────────────────────────
# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=evenova-assets

# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://evenova.ng

# ─── Ticket Signing ────────────────────────────────────────
TICKET_SECRET=EVENOVA_PRIME_NG_2025   # change in production!

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here